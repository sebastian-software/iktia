{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "jsxImportSource": "@naos-ui/core",
    "paths": {
      "@naos-ui/core": ["src/index.ts"],
      "@naos-ui/core/jsx-runtime": ["src/jsx-runtime.ts"],
      "@naos-ui/core/jsx-dev-runtime": ["src/jsx-dev-runtime.ts"]
    },
    "rootDir": "src",
    "tsBuildInfoFile": ".tsbuildinfo/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
