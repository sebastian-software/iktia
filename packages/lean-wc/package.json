{
  "name": "lean-wc",
  "version": "0.0.0",
  "description": "Authoring API and Vite integration for lean Web Components.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs"
    },
    "./jsx-runtime": {
      "types": "./src/jsx-runtime.ts",
      "import": "./src/jsx-runtime.ts",
      "require": "./dist/jsx-runtime.cjs"
    },
    "./jsx-dev-runtime": {
      "types": "./src/jsx-dev-runtime.ts",
      "import": "./src/jsx-dev-runtime.ts",
      "require": "./dist/jsx-dev-runtime.cjs"
    },
    "./runtime": {
      "types": "./src/runtime.ts",
      "import": "./src/runtime.ts",
      "require": "./dist/runtime.cjs"
    },
    "./vite": {
      "types": "./src/vite.ts",
      "import": "./src/vite.ts",
      "require": "./dist/vite.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "sideEffects": false,
  "files": ["dist/"],
  "scripts": {
    "build": "unbuild",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --globals src/*.test.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@lean-wc/core-node": "workspace:^"
  },
  "peerDependencies": {
    "vite": "^6 || ^7 || ^8"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.6"
  }
}
